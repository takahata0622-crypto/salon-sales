rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // 送信記録（全スタッフが閲覧可能・自分の名前の追加／削除のみ／他人の記録は変更不可）
    match /submitLog/{date} {
      allow read:   if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth != null
                    && request.resource.data.names is list
                    && (
                         // 自分の名前だけを追加する（他人の名前は消さない）。出勤人数のみの更新もここを通る（names不変）
                         (request.resource.data.names.hasAll(resource.data.names)
                          && resource.data.names.concat([request.auth.token.name]).hasAll(request.resource.data.names))
                         ||
                         // 自分の名前だけを削除する（未送信に戻す）
                         (resource.data.names.hasAll(request.resource.data.names)
                          && request.resource.data.names.concat([request.auth.token.name]).hasAll(resource.data.names))
                       );
      allow delete: if false;
    }
  }
}
