rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }
    // 送信記録（全スタッフが閲覧・追記可能）
    match /submitLog/{date} {
      allow read, write: if request.auth != null;
    }
  }
}
